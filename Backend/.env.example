# =============================================================================
# SCLM Cloud — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your real values.
# NEVER commit .env to version control.

# ─── Django Core ─────────────────────────────────────────────────────────────
DJANGO_SETTINGS_MODULE=sclm_backend.settings.dev
SECRET_KEY=replace-with-50-char-random-secret-key
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# ─── Neon DB (Serverless PostgreSQL 15+ with PostGIS) ────────────────────────
# Format: postgres://<user>:<password>@<host>/<dbname>?sslmode=require
# Get this from: https://console.neon.tech → Your Project → Connection String
DATABASE_URL='postgresql://neondb_owner:npg_atTis7uDVQz0@ep-round-resonance-ao0g1yav-pooler.c-2.ap-southeast-1.aws.neon.tech/neondb?sslmode=require&channel_binding=require
# ─── Redis (Celery Broker + Django Cache) ────────────────────────────────────
# Local dev: redis://127.0.0.1:6379/0
# Production (AWS ElastiCache): redis://your-elasticache-endpoint:6379/0
REDIS_URL=redis://127.0.0.1:6379/0

# ─── AWS S3 (ePOD Signatures & Return Photos) ────────────────────────────────
AWS_ACCESS_KEY_ID=YOUR_AWS_ACCESS_KEY
AWS_SECRET_ACCESS_KEY=YOUR_AWS_SECRET_KEY
AWS_STORAGE_BUCKET_NAME=sclm-cloud-epod
AWS_S3_REGION_NAME=us-east-1

# ─── CORS ────────────────────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
